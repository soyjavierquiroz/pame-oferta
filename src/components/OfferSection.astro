---
import { getElement, getSection, splitLines } from '../data/funnel';

const offerIntroSection = getSection('offer_intro');
const bridge = getElement(offerIntroSection, 'bridge');
const offerIntro = getElement(offerIntroSection, 'offer_intro');
const mechanism = getElement(offerIntroSection, 'mechanism');

const supportSection = getSection('deliverables_support');
const deliverable = getElement(supportSection, 'deliverable');
const support = getElement(supportSection, 'support');
const community = getElement(supportSection, 'community');
const access = getElement(supportSection, 'access');
const credential = getElement(supportSection, 'credential');

const recapSection = getSection('offer_stack_recap');
const quote = getElement(recapSection, 'quote');
const recap = getElement(recapSection, 'recap');
const benefits = getElement(recapSection, 'bullets');
const benefitItems = (benefits.items as string[]).map((item) => String(item));

const stackedCards = [
  { data: deliverable, image: '/imagenes/pack-3productos.webp' },
  { data: support, image: '/imagenes/en-vivo.webp' },
  { data: community, image: '/imagenes/comunidad.webp' },
  { data: access, image: '/imagenes/familia.jpg.webp' },
  { data: credential, image: '/imagenes/pame5.webp' },
];
---

<section id="offer_stack_recap" class="bg-brand-canvas-50 px-6 py-20 sm:px-10 lg:px-16 lg:py-28">
  <div class="mx-auto max-w-content space-y-12">
    <div class="space-y-6 text-center">
      <p class="font-display text-4xl font-semibold leading-tight text-brand-plum-900 sm:text-5xl">
        {String(bridge.copy)}
      </p>

      <div class="mx-auto max-w-4xl rounded-hero border border-brand-lilac-100 bg-white px-8 py-10 shadow-soft">
        {splitLines(String(offerIntro.copy)).map((line, index) => (
          <p
            class:list={[
              'text-brand-plum-800',
              index === 0
                ? 'font-display text-4xl font-semibold leading-tight sm:text-5xl'
                : 'mt-5 text-base leading-relaxed sm:text-lg',
            ]}
          >
            {line}
          </p>
        ))}
      </div>

      <div class="mx-auto max-w-4xl space-y-3">
        {splitLines(String(mechanism.copy)).map((line, index) => (
          <p
            class:list={[
              'text-brand-plum-700',
              index === 0 ? 'text-sm font-semibold tracking-[0.08em]' : 'text-base leading-relaxed sm:text-lg',
            ]}
          >
            {line}
          </p>
        ))}
      </div>
    </div>

    <div class="space-y-8">
      {stackedCards.map((item, index) => (
        <article class="grid gap-6 rounded-hero border border-brand-canvas-200 bg-white p-6 shadow-soft sm:p-8 lg:grid-cols-[0.34fr_0.66fr] lg:items-center">
          <div class:list={[index % 2 === 1 && 'lg:order-2']}>
            <img
              src={item.image}
              alt={String(item.data.title)}
              class="h-56 w-full rounded-3xl object-cover"
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class:list={['space-y-4', index % 2 === 1 && 'lg:order-1']}>
            <h3 class="font-display text-3xl font-semibold leading-tight text-brand-plum-900 sm:text-4xl">
              {String(item.data.title)}
            </h3>
            {splitLines(String(item.data.copy)).map((line) => (
              <p class="text-sm leading-relaxed text-brand-plum-700 sm:text-base">{line}</p>
            ))}
          </div>
        </article>
      ))}
    </div>

    <div class="space-y-6 rounded-hero border border-brand-lilac-100 bg-brand-lilac-50 px-6 py-8 shadow-soft sm:px-8 sm:py-10">
      <p class="text-center font-display text-3xl font-semibold leading-tight text-brand-plum-900 sm:text-4xl">
        {String(quote.copy)}
      </p>
      <p class="text-center text-base leading-relaxed text-brand-plum-700 sm:text-lg">{String(recap.copy)}</p>

      <div class="rounded-3xl bg-white p-6">
        <p class="text-sm font-bold tracking-[0.08em] text-brand-lilac-700">{String(benefits.title)}</p>
        <ul class="mt-5 space-y-3">
          {benefitItems.map((item) => (
            <li class="text-sm leading-relaxed text-brand-plum-800 sm:text-base">{item}</li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>
