---
import { getElement, getSection, splitLines } from '../data/funnel';

const offerIntroSection = getSection('offer_intro');
const bridge = getElement(offerIntroSection, 'bridge');
const offerIntro = getElement(offerIntroSection, 'offer_intro');
const mechanism = getElement(offerIntroSection, 'mechanism');

const supportSection = getSection('deliverables_support');
const deliverable = getElement(supportSection, 'deliverable');
const support = getElement(supportSection, 'support');
const community = getElement(supportSection, 'community');
const access = getElement(supportSection, 'access');
const credential = getElement(supportSection, 'credential');

const recapSection = getSection('offer_stack_recap');
const quote = getElement(recapSection, 'quote');
const recap = getElement(recapSection, 'recap');
const benefits = getElement(recapSection, 'bullets');
const benefitItems = (benefits.items as string[]).map((item) => String(item));

const stackedCards = [
  { data: deliverable, image: '/imagenes/pack-3productos.webp' },
  { data: support, image: '/imagenes/en-vivo.webp' },
  { data: community, image: '/imagenes/comunidad.webp' },
  { data: access, image: '/imagenes/familia.jpg.webp' },
  { data: credential, image: '/imagenes/pame5.webp' },
];
---

<section id="offer_stack_recap" class="section-breath bg-brand-canvas-50">
  <div class="reading-column space-y-14">
    <div class="space-y-6 text-center">
      <p class="text-4xl leading-[1.1] text-brand-plum-900 sm:text-5xl">
        {String(bridge.copy)}
      </p>

      <div class="floating-card mx-auto max-w-3xl px-8 py-12 sm:px-10">
        {splitLines(String(offerIntro.copy)).map((line, index) => (
          <p
            class:list={[
              'text-brand-plum-800',
              index === 0
                ? 'text-4xl leading-[1.1] sm:text-5xl'
                : 'mt-5 text-[15px] leading-[1.8] sm:text-base',
            ]}
          >
            {line}
          </p>
        ))}
      </div>

      <div class="mx-auto max-w-4xl space-y-3">
        {splitLines(String(mechanism.copy)).map((line, index) => (
          <p
            class:list={[
              'text-brand-plum-700',
              index === 0 ? 'text-sm font-semibold tracking-[0.12em]' : 'text-[15px] leading-[1.8] sm:text-base',
            ]}
          >
            {line}
          </p>
        ))}
      </div>
    </div>

    <div class="space-y-10">
      {stackedCards.map((item, index) => (
        <article class="grid gap-6 rounded-[3.5rem] bg-brand-lilac-50 p-5 shadow-around sm:p-6 lg:grid-cols-[0.34fr_0.66fr] lg:items-center">
          <div class:list={[index % 2 === 1 && 'lg:order-2']}>
            <img
              src={item.image}
              alt={String(item.data.title)}
              class="h-56 w-full rounded-[2.8rem] object-cover"
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class:list={['floating-card space-y-4 p-6 sm:p-8', index % 2 === 1 && 'lg:order-1']}>
            <h3 class="text-3xl leading-[1.1] text-brand-plum-900 sm:text-4xl">
              {String(item.data.title)}
            </h3>
            {splitLines(String(item.data.copy)).map((line) => (
              <p class="text-[15px] leading-[1.8] text-brand-plum-700">{line}</p>
            ))}
          </div>
        </article>
      ))}
    </div>

    <div class="space-y-6 rounded-[3.5rem] bg-brand-lilac-50 px-6 py-10 shadow-around sm:px-8 sm:py-12">
      <p class="text-center text-3xl leading-[1.1] text-brand-plum-900 sm:text-4xl">
        {String(quote.copy)}
      </p>
      <p class="text-center text-[15px] leading-[1.8] text-brand-plum-700 sm:text-base">{String(recap.copy)}</p>

      <div class="floating-card p-6 sm:p-8">
        <p class="text-sm font-semibold tracking-[0.12em] text-brand-lilac-700">{String(benefits.title)}</p>
        <ul class="mt-5 space-y-3">
          {benefitItems.map((item) => (
            <li class="text-[15px] leading-[1.8] text-brand-plum-800">{item}</li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>
