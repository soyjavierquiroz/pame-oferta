---
import copy from '../data/copy.json';

const { bonus } = copy;
---

<section class="bg-brand-lilac-50 px-6 py-16 sm:px-10 lg:px-16 lg:py-24">
  <div class="mx-auto max-w-content">
    <div class="space-y-6 text-center">
      <h2 class="font-display text-4xl font-semibold leading-tight text-brand-plum-900 sm:text-5xl">
        {bonus.title}
      </h2>
      <p class="text-lg font-semibold text-brand-gold-700">{bonus.value}</p>
      <p class="mx-auto max-w-3xl text-lg leading-8 text-brand-plum-700">{bonus.description}</p>
    </div>

    <div class="mt-10 space-y-10">
      {
        bonus.categories.map((category) => (
          <div class="space-y-5">
            <p class="text-sm font-bold uppercase tracking-serene text-brand-lilac-700">{category.title}</p>
            <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-4">
              {
                category.items.map((item) => (
                  <article class="overflow-hidden rounded-3xl border border-brand-lilac-100 bg-white shadow-soft xl:col-auto">
                    <img
                      src={item.image}
                      alt={item.title}
                      class="h-48 w-full object-cover"
                      loading="lazy"
                      decoding="async"
                    />
                    <div class="p-6">
                      <h3 class="font-display text-3xl font-semibold leading-tight text-brand-plum-900">
                        {item.title}
                      </h3>
                      <p class="mt-4 text-sm leading-7 text-brand-plum-700">{item.description}</p>
                    </div>
                  </article>
                ))
              }
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
