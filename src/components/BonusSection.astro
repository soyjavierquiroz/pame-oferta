---
import { getElements, getSection, splitLines } from '../data/funnel';

const section = getSection('bonuses');
const groups = getElements(section, 'bonus_group');
const special = getElement(section, 'bonus_special');

function getElement(sectionRef: typeof section, type: string) {
  const element = sectionRef.elements.find((item) => item.type === type);
  if (!element) {
    throw new Error(`Missing element "${type}" in section "${sectionRef.id}"`);
  }
  return element as Record<string, unknown>;
}

const titleLines = splitLines(String(getElement(section, 'section_title').copy));
const bonusImages = [
  '/imagenes/fotoyvideos.webp',
  '/imagenes/emprende.webp',
  '/imagenes/kit-calculadora-magica.webp',
  '/imagenes/reto-21-dias.webp',
  '/imagenes/envio-perfecto.webp',
  '/imagenes/jc_logo.png.webp',
  '/imagenes/disena-canva.webp',
  '/imagenes/imprime-y-vende.webp',
  '/imagenes/bonos.webp',
];

let imageIndex = 0;
const groupedBonuses = groups.map((group) => {
  const mappedItems = ((group.items as Array<Record<string, unknown>>) || []).map((item) => {
    const mapped = {
      title: String(item.title),
      copyLines: splitLines(String(item.copy)),
      image: bonusImages[imageIndex],
    };
    imageIndex += 1;
    return mapped;
  });

  return {
    title: String(group.title),
    mappedItems,
  };
});

const specialItem = {
  title: String((special.item as Record<string, unknown>).title),
  copyLines: splitLines(String((special.item as Record<string, unknown>).copy)),
};
---

<section id="bonuses" class="bg-white px-[10%] py-32 sm:px-10 lg:px-16">
  <div class="mx-auto max-w-4xl space-y-14">
    <div class="mx-auto max-w-2xl space-y-4 text-center">
      {
        titleLines.map((line, index) => (
          <p
            class:list={[
              index === 0 ? 'text-4xl tracking-[-0.02em] text-brand-plum-900 sm:text-5xl' : 'text-[15px] leading-loose text-brand-plum-700',
            ]}
          >
            {line}
          </p>
        ))
      }
    </div>

    {
      groupedBonuses.map((group) => (
        <div class="space-y-6">
          <p class="text-center text-sm font-semibold tracking-[0.14em] text-brand-lilac-600">{group.title}</p>
          <div class="space-y-6">
            {
              group.mappedItems.map((item) => (
                <article class="rounded-[3rem] bg-brand-canvas-50 p-5 shadow-sm sm:p-6">
                  <div class="grid gap-5 lg:grid-cols-[0.3fr_0.7fr] lg:items-center">
                    <img
                      src={item.image}
                      alt={item.title}
                      class="h-52 w-full rounded-[2.5rem] object-cover"
                      loading="lazy"
                      decoding="async"
                    />
                    <div class="space-y-4 rounded-[2.5rem] bg-white p-5 shadow-sm sm:p-6">
                      <h3 class="text-3xl leading-tight tracking-[-0.02em] text-brand-plum-900">{item.title}</h3>
                      {
                        item.copyLines.map((line) => (
                          <p class="text-[15px] leading-loose text-brand-plum-700">{line}</p>
                        ))
                      }
                    </div>
                  </div>
                </article>
              ))
            }
          </div>
        </div>
      ))
    }

    <div class="space-y-6">
      <p class="text-center text-sm font-semibold tracking-[0.14em] text-brand-lilac-600">{String(special.title)}</p>
      <article class="rounded-[3rem] bg-brand-canvas-50 p-5 shadow-sm sm:p-6">
        <div class="grid gap-5 lg:grid-cols-[0.3fr_0.7fr] lg:items-center">
          <img
            src={bonusImages[bonusImages.length - 1]}
            alt={specialItem.title}
            class="h-56 w-full rounded-[2.5rem] object-cover"
            loading="lazy"
            decoding="async"
          />
          <div class="space-y-4 rounded-[2.5rem] bg-white p-5 shadow-sm sm:p-6">
            <h3 class="text-3xl leading-tight tracking-[-0.02em] text-brand-plum-900">{specialItem.title}</h3>
            {
              specialItem.copyLines.map((line) => (
                <p class="text-[15px] leading-loose text-brand-plum-700">{line}</p>
              ))
            }
          </div>
        </div>
      </article>
    </div>
  </div>
</section>
