---
import copy from '../data/copy.json';

const { bonus } = copy;
---

<section class="bg-brand-lilac-50 px-6 py-16 sm:px-10 lg:px-16 lg:py-24">
  <div class="mx-auto max-w-content">
    <div class="rounded-hero border border-brand-lilac-200/80 bg-white p-8 shadow-soft md:p-10 xl:p-12">
      <div class="grid gap-10 xl:grid-cols-[0.9fr_1.1fr] xl:items-start">
        <div class="space-y-6">
          <span class="inline-flex rounded-full border border-brand-lilac-200 bg-brand-lilac-100 px-4 py-2 text-xs font-bold uppercase tracking-serene text-brand-plum-700">
            {bonus.eyebrow}
          </span>
          <div class="inline-flex rounded-full bg-brand-gold-300 px-4 py-2 text-xs font-extrabold uppercase tracking-serene text-brand-plum-900 shadow-glow">
            {bonus.badge}
          </div>
          <h2 class="font-display text-4xl font-semibold leading-tight text-brand-plum-900 sm:text-5xl">
            {bonus.title}
          </h2>
          <p class="text-lg leading-8 text-brand-plum-700">
            {bonus.description}
          </p>
          <p class="rounded-3xl border border-brand-gold-200 bg-brand-gold-100 px-5 py-4 text-sm font-semibold text-brand-gold-800">
            {bonus.footnote}
          </p>
        </div>

        <div class="grid gap-5">
          {
            bonus.items.map((item) => (
              <article class="rounded-3xl border border-brand-lilac-100 bg-brand-plum-800 p-6 text-white shadow-soft">
                <div class="flex items-start justify-between gap-4">
                  <h3 class="font-display text-3xl font-semibold leading-tight text-white">{item.title}</h3>
                  <span class="inline-flex h-10 w-10 flex-none items-center justify-center rounded-full bg-brand-gold-300 text-sm font-bold text-brand-plum-900">
                    +
                  </span>
                </div>
                <p class="mt-4 text-base leading-8 text-brand-lilac-100">{item.description}</p>
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>

