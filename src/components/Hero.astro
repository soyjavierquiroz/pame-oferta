---
import copy from '../data/copy.json';

const { hero } = copy;
---

<section class="relative isolate overflow-hidden px-6 pb-20 pt-8 sm:px-10 lg:px-16 lg:pb-24 lg:pt-12">
  <div class="absolute inset-x-0 top-0 -z-20 h-[38rem] bg-hero-glow"></div>
  <div class="absolute -left-16 top-24 -z-10 h-56 w-56 rounded-[38%_62%_54%_46%/43%_48%_52%_57%] bg-brand-lilac-200/70 blur-3xl"></div>
  <div class="absolute -right-12 bottom-20 -z-10 h-64 w-64 rounded-[55%_45%_35%_65%/45%_61%_39%_55%] bg-brand-gold-200/80 blur-3xl"></div>

  <div class="mx-auto grid max-w-content gap-10 rounded-hero border border-brand-lilac-100/80 bg-white/90 p-8 shadow-soft backdrop-blur md:p-10 xl:grid-cols-[1.08fr_0.92fr] xl:p-12">
    <div class="space-y-8">
      <p class="max-w-2xl text-sm font-semibold tracking-[0.08em] text-brand-lilac-700">
        {hero.eyebrow}
      </p>

      <div class="space-y-5">
        <h1 class="max-w-3xl font-display text-5xl font-semibold leading-tight text-brand-plum-900 sm:text-6xl lg:text-7xl">
          {hero.headline}
        </h1>
        <p class="font-display text-3xl font-semibold text-brand-gold-700 sm:text-4xl">{hero.subheadline}</p>
        <p class="max-w-2xl text-lg leading-8 text-brand-plum-700 sm:text-xl">
          {hero.description}
        </p>
      </div>

      <div class="flex flex-col gap-4 sm:flex-row sm:items-center">
        <a
          href={hero.cta.href}
          class="button-focus inline-flex items-center justify-center rounded-full bg-brand-gold-300 px-7 py-4 text-sm font-bold uppercase tracking-[0.16em] text-brand-plum-900 shadow-glow transition duration-300 hover:-translate-y-0.5 hover:bg-brand-gold-400 animate-pulse hover:animate-none"
        >
          {hero.cta.label}
        </a>
      </div>

      <div class="flex flex-wrap gap-3">
        {
          hero.quickFacts.map((fact) => (
            <span class="rounded-full bg-brand-canvas-50 px-4 py-2 text-sm font-semibold text-brand-plum-700 ring-1 ring-inset ring-brand-canvas-200">
              {fact}
            </span>
          ))
        }
      </div>
    </div>

    <div class="relative rounded-hero bg-brand-plum-800 p-6 text-white shadow-soft sm:p-8">
      <div class="absolute right-6 top-6 h-20 w-20 rounded-[62%_38%_58%_42%/38%_42%_58%_62%] bg-brand-gold-300/90 blur-2xl"></div>
      <img
        src={hero.image.src}
        alt={hero.image.alt}
        class="relative z-10 mx-auto h-72 w-full rounded-3xl object-cover object-top"
        loading="eager"
        decoding="async"
      />
      <div class="relative z-10 mt-6 rounded-3xl bg-white px-5 py-6 text-brand-plum-900">
        <p class="font-display text-3xl font-semibold leading-tight text-brand-plum-800">{hero.fitTitle}</p>
        <ul class="mt-5 space-y-3">
          {
            hero.fitItems.map((item) => (
              <li class="flex items-start gap-3">
                <span class="mt-1 inline-flex h-6 w-6 flex-none items-center justify-center rounded-full bg-brand-gold-100 text-xs font-bold text-brand-gold-700">
                  +
                </span>
                <span class="text-sm leading-7 text-brand-plum-700">{item}</span>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>
</section>
