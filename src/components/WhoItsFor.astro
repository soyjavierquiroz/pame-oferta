---
import { getElement, getSection } from '../data/funnel';

const section = getSection('who_its_for');
const title = getElement(section, 'section_title');
const bullets = getElement(section, 'audience_bullets');
const cta = getElement(section, 'cta_repeat');
const audienceItems = (bullets.items as string[]).map((item) => String(item));
---

<section id="who_its_for" class="bg-brand-canvas-50 px-[10%] py-32 sm:px-10 lg:px-16">
  <div class="mx-auto max-w-4xl">
    <div class="mx-auto max-w-2xl space-y-12 text-center">
      <p class="text-4xl leading-[1.18] tracking-[-0.02em] text-brand-plum-900 sm:text-5xl">
        {String(title.copy)}
      </p>

      <div class="space-y-5 rounded-[3rem] bg-white px-5 py-6 shadow-sm sm:px-7 sm:py-8">
        {
          audienceItems.map((item) => (
            <p class="rounded-[2.25rem] bg-brand-canvas-50 px-5 py-4 text-left text-[15px] font-normal leading-loose text-brand-plum-800 shadow-sm">
              {item}
            </p>
          ))
        }

        <a
          href="#price_guarantee_checkout"
          class="button-focus inline-flex items-center justify-center rounded-full bg-brand-gold-300 px-8 py-4 text-sm font-semibold uppercase tracking-[0.18em] text-black shadow-sm transition duration-300 hover:-translate-y-0.5 hover:bg-brand-gold-400"
        >
          {String(cta.copy)}
        </a>
      </div>
    </div>
  </div>
</section>
