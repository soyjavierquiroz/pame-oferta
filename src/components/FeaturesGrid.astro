---
import { getElements, getSection, splitLines } from '../data/funnel';

const section = getSection('curriculum');
const phases = getElements(section, 'phase');

const images = [
  '/imagenes/kit-principiante-experta.webp',
  '/imagenes/disena-canva.webp',
  '/imagenes/shopping-feliz.webp',
  '/imagenes/familia.jpg.webp',
];
---

<section id="curriculum" class="section-breath bg-white">
  <div class="reading-column space-y-10">
    {phases.map((item, index) => (
      <article class="grid gap-6 rounded-[3.5rem] bg-brand-canvas-100 p-5 shadow-around sm:p-6 lg:grid-cols-[0.32fr_0.68fr] lg:items-center">
        <div class:list={[index % 2 === 1 && 'lg:order-2']}>
          <img
            src={images[index]}
            alt={String(item.title)}
            class="h-56 w-full rounded-[2.8rem] object-cover"
            loading="lazy"
            decoding="async"
          />
        </div>
        <div class:list={['floating-card space-y-4 p-6 sm:p-8', index % 2 === 1 && 'lg:order-1']}>
          <p class="text-3xl leading-[1.1] text-brand-plum-900 sm:text-4xl">
            {String(item.title)}
          </p>
          {splitLines(String(item.copy)).map((line) => (
            <p class="text-[15px] leading-[1.8] text-brand-plum-700">{line}</p>
          ))}
        </div>
      </article>
    ))}
  </div>
</section>
