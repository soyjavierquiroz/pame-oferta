---
import { getElements, getSection, splitLines } from '../data/funnel';

const section = getSection('curriculum');
const phases = getElements(section, 'phase');

const images = [
  '/imagenes/kit-principiante-experta.webp',
  '/imagenes/disena-canva.webp',
  '/imagenes/shopping-feliz.webp',
  '/imagenes/familia.jpg.webp',
];
---

<section id="curriculum" class="bg-white px-6 py-20 sm:px-10 lg:px-16 lg:py-28">
  <div class="mx-auto max-w-content space-y-8">
    {phases.map((item, index) => (
      <article class="grid gap-6 rounded-hero border border-brand-canvas-200 bg-brand-canvas-50 p-6 shadow-soft sm:p-8 lg:grid-cols-[0.32fr_0.68fr] lg:items-center">
        <div class:list={[index % 2 === 1 && 'lg:order-2']}>
          <img
            src={images[index]}
            alt={String(item.title)}
            class="h-56 w-full rounded-3xl object-cover"
            loading="lazy"
            decoding="async"
          />
        </div>
        <div class:list={['space-y-4', index % 2 === 1 && 'lg:order-1']}>
          <p class="font-display text-3xl font-semibold leading-tight text-brand-plum-900 sm:text-4xl">
            {String(item.title)}
          </p>
          {splitLines(String(item.copy)).map((line) => (
            <p class="text-sm leading-relaxed text-brand-plum-700 sm:text-base">{line}</p>
          ))}
        </div>
      </article>
    ))}
  </div>
</section>

