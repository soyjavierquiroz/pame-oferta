---
import copy from '../data/copy.json';

const { phases } = copy;
---

<section id="beneficios" class="bg-brand-canvas-50 px-6 py-16 sm:px-10 lg:px-16 lg:py-24">
  <div class="mx-auto max-w-content">
    <div class="max-w-3xl space-y-5">
      <p class="text-sm font-semibold tracking-[0.08em] text-brand-lilac-700">{phases.eyebrow}</p>
      <h2 class="font-display text-4xl font-semibold leading-tight text-brand-plum-900 sm:text-5xl">
        {phases.title}
      </h2>
      <p class="text-lg leading-8 text-brand-plum-700">
        {phases.description}
      </p>
    </div>

    <div class="mt-10 grid gap-6 md:grid-cols-2">
      {
        phases.items.map((item) => (
          <article class="overflow-hidden rounded-3xl border border-brand-canvas-200 bg-white shadow-soft">
            <img
              src={item.image}
              alt={item.title}
              class="h-52 w-full object-cover"
              loading="lazy"
              decoding="async"
            />
            <div class="p-7">
              <span class="inline-flex rounded-full bg-brand-gold-100 px-3 py-2 text-xs font-bold uppercase tracking-serene text-brand-gold-700">
                {item.phase}
              </span>
              <h3 class="mt-5 font-display text-3xl font-semibold leading-tight text-brand-plum-800">
                {item.title}
              </h3>
              <p class="mt-4 text-base leading-8 text-brand-plum-700">
                {item.description}
              </p>
            </div>
          </article>
        ))
      }
    </div>

    <div class="mt-10 grid gap-8 rounded-hero border border-brand-lilac-100 bg-brand-lilac-50 p-8 shadow-soft lg:grid-cols-[0.95fr_1.05fr] lg:items-center">
      <div>
        <img
          src={phases.modelsImage}
          alt={phases.modelsTitle}
          class="h-72 w-full rounded-3xl object-cover"
          loading="lazy"
          decoding="async"
        />
      </div>
      <div class="space-y-5">
        <h3 class="font-display text-4xl font-semibold leading-tight text-brand-plum-900">
          {phases.modelsTitle}
        </h3>
        <p class="text-base leading-8 text-brand-plum-700">{phases.modelsIntro}</p>
        <ul class="space-y-3">
          {
            phases.modelsBullets.map((item) => (
              <li class="flex items-start gap-3">
                <span class="mt-1 inline-flex h-6 w-6 flex-none items-center justify-center rounded-full bg-brand-gold-100 text-xs font-bold text-brand-gold-700">
                  +
                </span>
                <span class="text-base leading-7 text-brand-plum-700">{item}</span>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>
</section>
