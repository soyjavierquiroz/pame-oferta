---
import copy from '../data/copy.json';

const { socialProof } = copy;
---

<section class="bg-brand-mint-100 bg-chat-grid bg-[length:1.4rem_1.4rem,auto] px-6 py-16 sm:px-10 lg:px-16 lg:py-24">
  <div class="mx-auto max-w-content">
    <div class="grid gap-10 xl:grid-cols-[0.9fr_1.1fr] xl:items-start">
      <div class="max-w-2xl space-y-5">
        <span class="inline-flex rounded-full border border-brand-mint-300 bg-brand-mint-50 px-4 py-2 text-xs font-bold uppercase tracking-serene text-brand-mint-700">
          {socialProof.eyebrow}
        </span>
        <h2 class="font-display text-4xl font-semibold leading-tight text-brand-plum-900 sm:text-5xl">
          {socialProof.title}
        </h2>
        <p class="text-lg leading-8 text-brand-plum-700">
          {socialProof.description}
        </p>
      </div>

      <div class="grid gap-6 md:grid-cols-2">
        {
          socialProof.messages.map((message, index) => (
            <article
              class:list={[
                'rounded-[2rem] border border-brand-mint-200 bg-white p-5 shadow-soft',
                index === 1 && 'md:translate-y-10',
                index === 2 && 'md:col-span-2 md:max-w-xl md:justify-self-center',
              ]}
            >
              <div class="flex items-center justify-between gap-4 border-b border-brand-mint-100 pb-4">
                <div>
                  <p class="font-semibold text-brand-plum-900">{message.name}</p>
                  <p class="text-sm text-brand-mint-700">{message.role}</p>
                </div>
                <span class="text-xs font-bold uppercase tracking-serene text-brand-mint-600">
                  {message.time}
                </span>
              </div>

              <div class="mt-4 flex justify-start">
                <div class="max-w-md rounded-[1.5rem_1.5rem_1.5rem_0.5rem] bg-brand-mint-50 px-4 py-4 text-sm leading-7 text-brand-plum-800 ring-1 ring-inset ring-brand-mint-100">
                  {message.message}
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </div>
</section>

