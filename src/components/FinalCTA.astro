---
import copy from '../data/copy.json';

const { offer } = copy;
---

<section id="conversion" class="bg-brand-plum-900 px-6 py-16 sm:px-10 lg:px-16 lg:py-24">
  <div class="mx-auto grid max-w-content gap-10 rounded-hero border border-white/10 bg-brand-plum-800 p-8 shadow-soft md:p-10 xl:grid-cols-[0.95fr_1.05fr] xl:p-12">
    <div class="space-y-6">
      <span class="inline-flex rounded-full bg-white/10 px-4 py-2 text-xs font-bold uppercase tracking-serene text-brand-gold-100">
        {offer.eyebrow}
      </span>
      <h2 class="font-display text-4xl font-semibold leading-tight text-white sm:text-5xl">
        {offer.title}
      </h2>
      <p class="text-lg leading-8 text-brand-lilac-100">
        {offer.description}
      </p>

      <div class="rounded-3xl border border-brand-gold-300/30 bg-brand-gold-300/10 p-6">
        <p class="text-sm font-bold uppercase tracking-serene text-brand-gold-100">{offer.priceLabel}</p>
        <p class="mt-3 font-display text-5xl font-semibold text-brand-gold-300 sm:text-6xl">{offer.price}</p>
        <p class="mt-4 text-sm leading-7 text-brand-lilac-50">{offer.priceFootnote}</p>
      </div>
    </div>

    <div class="rounded-3xl bg-white p-6 text-brand-plum-900 sm:p-8">
      <p class="text-sm font-bold uppercase tracking-serene text-brand-lilac-600">{offer.includesTitle}</p>
      <ul class="mt-6 space-y-4">
        {
          offer.includes.map((item) => (
            <li class="flex items-start gap-3">
              <span class="mt-1 inline-flex h-6 w-6 flex-none items-center justify-center rounded-full bg-brand-gold-100 text-xs font-bold text-brand-gold-700">+</span>
              <span class="text-base leading-7 text-brand-plum-800">{item}</span>
            </li>
          ))
        }
      </ul>

      <a
        href={offer.primaryCta.href}
        class="button-focus mt-8 inline-flex w-full items-center justify-center rounded-full bg-brand-gold-300 px-7 py-4 text-sm font-bold uppercase tracking-[0.16em] text-brand-plum-900 shadow-glow transition duration-300 hover:-translate-y-0.5 hover:bg-brand-gold-400"
      >
        {offer.primaryCta.label}
      </a>

      <p class="mt-5 text-sm leading-7 text-brand-plum-600">{offer.secondaryNote}</p>
    </div>
  </div>
</section>
