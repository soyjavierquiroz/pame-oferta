---
import PaymentRescueBanner from './PaymentRescueBanner.astro';
import { funnel, getElement, getSection, splitLines } from '../data/funnel';

const priceSection = getSection('price_guarantee_checkout');
const priceAnchor = getElement(priceSection, 'price_anchor');
const cta = getElement(priceSection, 'cta_primary');
const guarantee = getElement(priceSection, 'guarantee');

const proofSection = getSection('social_proof');
const proofTitle = getElement(proofSection, 'section_title');
const proofAsset = getElement(proofSection, 'proof_asset');

const qualification = getSection('qualification');
const yesTitle = qualification.elements[0] as Record<string, unknown>;
const yesBullets = qualification.elements[1] as Record<string, unknown>;
const noTitle = qualification.elements[2] as Record<string, unknown>;
const noBullets = qualification.elements[3] as Record<string, unknown>;

const finalContact = getSection('final_contact');
const finalCta = getElement(finalContact, 'cta_primary');
const supportCta = getElement(finalContact, 'support_cta');
const yesItems = (yesBullets.items as string[]).map((item) => String(item));
const noItems = (noBullets.items as string[]).map((item) => String(item));
const stickyMobile = funnel.conversion_addons_recommended.sticky_cta_mobile;

const proofImages = [
  '/imagenes/Testimonio-1-1-1-1024x818.jpg.webp',
  '/imagenes/Testimonio-2-1-1-879x1024.jpg.webp',
  '/imagenes/t2-2-1024x1008.jpg.webp',
  '/imagenes/t3-2-1024x825.jpg.webp',
  '/imagenes/t4-2-1024x823.jpg.webp',
];
---

<section id="price_guarantee_checkout" class="section-breath bg-brand-lilac-50">
  <div class="reading-column space-y-14">
    <div class="grid gap-8 rounded-[3.5rem] bg-brand-canvas-100 p-5 shadow-around sm:p-6 lg:grid-cols-[0.9fr_1.1fr]">
      <div class="space-y-6">
        <div class="floating-card p-6 sm:p-8">
          {splitLines(String(priceAnchor.copy)).map((line, index) => (
            <p
              class:list={[
                index === 0
                  ? 'text-sm font-semibold tracking-[0.12em] text-brand-lilac-600'
                  : 'mt-4 text-5xl leading-none text-brand-plum-900 sm:text-6xl',
              ]}
            >
              {line}
            </p>
          ))}
        </div>

        <a
          href="https://oferta.pameflorescrea.com"
          class="cta-premium w-full"
        >
          {String(cta.copy)}
        </a>

        <PaymentRescueBanner compact />
      </div>

      <div class="space-y-6">
        <div class="floating-card p-6 text-brand-plum-900 sm:p-8">
          {splitLines(String(guarantee.copy)).map((line, index) => (
            <p
              class:list={[
                index === 0
                  ? 'text-3xl leading-[1.1] text-brand-plum-900 sm:text-4xl'
                  : 'mt-3 text-[15px] leading-[1.8] text-brand-plum-700',
              ]}
            >
              {line}
            </p>
          ))}
        </div>

        <div id="social_proof" class="space-y-5">
          <p class="text-4xl leading-[1.1] text-brand-plum-900 sm:text-5xl">{String(proofTitle.copy)}</p>
          <p class="text-sm font-semibold tracking-[0.12em] text-brand-lilac-600">{String(proofAsset.copy)}</p>
          <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-5">
            {proofImages.map((image, index) => (
              <div class="overflow-hidden rounded-[2.5rem] bg-white shadow-sm">
                <img
                  src={image}
                  alt={`${String(proofTitle.copy)} ${index + 1}`}
                  class="h-full w-full object-cover"
                  loading="lazy"
                  decoding="async"
                />
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>

    <div id="qualification" class="grid gap-6 lg:grid-cols-2">
      <div class="floating-card p-6 sm:p-8">
        <p class="text-3xl leading-[1.1] text-brand-plum-900 sm:text-4xl">
          {String(yesTitle.copy)}
        </p>
        <ul class="mt-6 space-y-3">
          {yesItems.map((item) => (
            <li class="text-[15px] leading-[1.8] text-brand-plum-700">{item}</li>
          ))}
        </ul>
      </div>

      <div class="rounded-[3.5rem] bg-brand-canvas-100 p-6 shadow-around sm:p-8">
        <p class="text-3xl leading-[1.1] text-brand-plum-900 sm:text-4xl">
          {String(noTitle.copy)}
        </p>
        <ul class="mt-6 space-y-3">
          {noItems.map((item) => (
            <li class="text-[15px] leading-[1.8] text-brand-plum-700">{item}</li>
          ))}
        </ul>
      </div>
    </div>

    <div id="final_contact" class="rounded-[3.5rem] bg-white p-6 text-center shadow-around sm:p-8">
      <div class="mx-auto max-w-3xl space-y-5">
        <a
          href="https://oferta.pameflorescrea.com"
          class="cta-premium w-full sm:w-auto"
        >
          {String(finalCta.copy)}
        </a>

        <a
          href="https://wa.link/ugkgkj"
          class="button-focus inline-flex w-full items-center justify-center gap-3 rounded-full bg-brand-canvas-50 px-7 py-4 text-sm font-semibold uppercase tracking-widest text-brand-lilac-700 shadow-sm transition duration-300 hover:-translate-y-0.5 hover:bg-brand-canvas-100 sm:w-auto"
        >
          <span class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-brand-mint-500 text-white shadow-sm">
            <svg viewBox="0 0 24 24" class="h-4 w-4 fill-current" aria-hidden="true">
              <path d="M20.52 3.48A11.86 11.86 0 0 0 12.09 0C5.52 0 .19 5.33.19 11.9c0 2.1.55 4.15 1.59 5.95L0 24l6.31-1.65a11.9 11.9 0 0 0 5.78 1.48h.01c6.56 0 11.9-5.34 11.9-11.91 0-3.18-1.24-6.16-3.48-8.44ZM12.1 21.82h-.01a9.88 9.88 0 0 1-5.03-1.38l-.36-.22-3.75.98 1-3.65-.24-.37a9.84 9.84 0 0 1-1.52-5.28c0-5.46 4.44-9.9 9.9-9.9 2.64 0 5.12 1.03 6.99 2.91a9.82 9.82 0 0 1 2.9 6.99c0 5.46-4.45 9.91-9.88 9.91Zm5.43-7.42c-.3-.15-1.77-.87-2.04-.97-.27-.1-.47-.15-.66.15-.2.3-.76.97-.94 1.17-.17.2-.35.22-.64.07-.3-.15-1.26-.46-2.4-1.47-.89-.79-1.49-1.77-1.66-2.07-.18-.3-.02-.46.13-.61.13-.13.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.08-.15-.67-1.62-.92-2.22-.24-.58-.49-.5-.66-.5h-.56c-.2 0-.52.07-.8.37-.27.3-1.04 1.02-1.04 2.49s1.07 2.88 1.22 3.08c.15.2 2.1 3.2 5.08 4.49.71.3 1.27.48 1.7.61.72.23 1.38.2 1.9.12.58-.09 1.77-.72 2.02-1.42.25-.69.25-1.28.18-1.41-.08-.12-.28-.2-.58-.35Z" />
            </svg>
          </span>
          {String(supportCta.copy)}
        </a>
      </div>
    </div>
  </div>
</section>

{
  stickyMobile.enabled && (
    <div class="fixed inset-x-0 bottom-0 z-50 bg-white/95 px-4 pb-[calc(0.75rem+env(safe-area-inset-bottom))] pt-3 backdrop-blur md:hidden">
      <div class="mx-auto flex max-w-4xl items-center gap-3 rounded-[2rem] bg-brand-canvas-50 px-3 py-3 shadow-around">
        <a
          href="https://oferta.pameflorescrea.com"
          class="cta-premium flex-1 px-5 py-3 text-xs"
        >
          {stickyMobile.cta_copy}
        </a>
        <a
          href="https://wa.link/ugkgkj"
          class="button-focus inline-flex items-center justify-center rounded-full bg-white px-4 py-3 text-[0.7rem] font-semibold uppercase tracking-widest text-brand-lilac-700 shadow-sm"
        >
          {String(stickyMobile.secondary_link_optional)}
        </a>
      </div>
    </div>
  )
}
