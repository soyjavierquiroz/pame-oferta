---
import { getElement, getSection } from '../data/funnel';

interface Props {
  compact?: boolean;
}

const { compact = false } = Astro.props;

const section = compact ? getSection('price_guarantee_checkout') : getSection('payment_friction_fix');
const rescue = compact
  ? getElement(section, 'ui_block_optional')
  : getElement(section, 'ui_block_optional');
const note = compact ? null : getElements(section, 'ui_block_optional')[1];

function getElements(sectionRef: typeof section, type: string) {
  return sectionRef.elements.filter((item) => item.type === type) as Array<Record<string, unknown>>;
}
---

<div
  class:list={[
    'rounded-3xl border border-brand-gold-200 bg-brand-gold-100 shadow-soft',
    compact ? 'p-5' : 'px-6 py-5 sm:px-8 sm:py-6',
  ]}
>
  <div class="flex items-start gap-4">
    <span class="inline-flex h-12 w-12 flex-none items-center justify-center rounded-2xl bg-white text-brand-mint-600 shadow-soft">
      <svg viewBox="0 0 24 24" class="h-7 w-7 fill-current" aria-hidden="true">
        <path d="M20.52 3.48A11.86 11.86 0 0 0 12.09 0C5.52 0 .19 5.33.19 11.9c0 2.1.55 4.15 1.59 5.95L0 24l6.31-1.65a11.9 11.9 0 0 0 5.78 1.48h.01c6.56 0 11.9-5.34 11.9-11.91 0-3.18-1.24-6.16-3.48-8.44ZM12.1 21.82h-.01a9.88 9.88 0 0 1-5.03-1.38l-.36-.22-3.75.98 1-3.65-.24-.37a9.84 9.84 0 0 1-1.52-5.28c0-5.46 4.44-9.9 9.9-9.9 2.64 0 5.12 1.03 6.99 2.91a9.82 9.82 0 0 1 2.9 6.99c0 5.46-4.45 9.91-9.88 9.91Zm5.43-7.42c-.3-.15-1.77-.87-2.04-.97-.27-.1-.47-.15-.66.15-.2.3-.76.97-.94 1.17-.17.2-.35.22-.64.07-.3-.15-1.26-.46-2.4-1.47-.89-.79-1.49-1.77-1.66-2.07-.18-.3-.02-.46.13-.61.13-.13.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.08-.15-.67-1.62-.92-2.22-.24-.58-.49-.5-.66-.5h-.56c-.2 0-.52.07-.8.37-.27.3-1.04 1.02-1.04 2.49s1.07 2.88 1.22 3.08c.15.2 2.1 3.2 5.08 4.49.71.3 1.27.48 1.7.61.72.23 1.38.2 1.9.12.58-.09 1.77-.72 2.02-1.42.25-.69.25-1.28.18-1.41-.08-.12-.28-.2-.58-.35Z" />
      </svg>
    </span>

    <div class="min-w-0 flex-1 space-y-3">
      <p class="text-sm leading-relaxed text-brand-plum-800">
        {String(rescue.copy_suggestion_optional)}
      </p>

      {
        !compact && note && (
          <p class="text-sm leading-relaxed text-brand-plum-700">
            {String(note.copy_suggestion_optional)}
          </p>
        )
      }

      <a
        href="https://wa.link/ugkgkj"
        class="button-focus inline-flex items-center justify-center rounded-full bg-brand-plum-700 px-5 py-3 text-xs font-bold uppercase tracking-[0.14em] text-white transition duration-300 hover:-translate-y-0.5 hover:bg-brand-plum-800"
      >
        {String(rescue.cta_optional)}
      </a>
    </div>
  </div>
</div>

