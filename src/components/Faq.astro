---
import copy from '../data/copy.json';

const { faq } = copy;
---

<section class="bg-brand-canvas-100 px-6 py-16 sm:px-10 lg:px-16 lg:py-24">
  <div class="mx-auto max-w-content">
    <div class="mt-10 grid gap-4">
      {
        faq.items.map((item, index) => (
          <details class="group rounded-3xl border border-brand-canvas-200 bg-white p-6 shadow-soft" open={index === 0}>
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 [&::-webkit-details-marker]:hidden">
              <span class="pr-4 text-lg font-semibold text-brand-plum-900">{item.question}</span>
              <span class="inline-flex h-9 w-9 flex-none items-center justify-center rounded-full bg-brand-lilac-100 text-xl font-bold text-brand-lilac-700 transition duration-300 group-open:rotate-45">
                +
              </span>
            </summary>
            <ul class="mt-4 space-y-3 pr-12">
              {
                item.answers.map((answer) => (
                  <li class="flex items-start gap-3">
                    <span class="mt-1 inline-flex h-6 w-6 flex-none items-center justify-center rounded-full bg-brand-gold-100 text-xs font-bold text-brand-gold-700">
                      +
                    </span>
                    <span class="text-base leading-8 text-brand-plum-700">{answer}</span>
                  </li>
                ))
              }
            </ul>
          </details>
        ))
      }
    </div>

    <a
      href={faq.contactHref}
      class="button-focus mt-8 flex rounded-3xl border border-brand-gold-200 bg-brand-gold-100 px-6 py-5 text-center shadow-soft transition duration-300 hover:-translate-y-0.5 hover:bg-brand-gold-200"
    >
      <span class="w-full font-display text-3xl font-semibold text-brand-plum-900">{faq.contactTitle}</span>
    </a>
  </div>
</section>
