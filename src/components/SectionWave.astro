---
interface Props {
  flip?: boolean;
  className?: string;
  variant?: 'wave' | 'cloud';
}

const { flip = false, className = '', variant = 'wave' } = Astro.props;
const cloudPath =
  'M0 82c34 0 34-28 68-28s34 28 68 28 34-24 68-24 34 24 68 24 34-30 68-30 34 30 68 30 34-22 68-22 34 22 68 22 34-26 68-26 34 26 68 26 34-24 68-24 34 24 68 24 34-28 68-28 34 28 68 28V120H0Z';
const wavePath =
  'M0 54.23C130.79 92.42 261.58 111.52 392.36 111.52C523.15 111.52 653.94 53.16 784.73 53.16C915.52 53.16 1046.3 111.52 1177.09 111.52C1307.88 111.52 1373.94 96.16 1440 80.79V120H0V54.23Z';
---

<div class:list={['relative -mt-px leading-none text-brand-canvas-50', className]}>
  <svg
    class:list={['block h-16 w-full sm:h-24', flip && 'rotate-180']}
    viewBox="0 0 1440 120"
    preserveAspectRatio="none"
    aria-hidden="true"
  >
    <path d={variant === 'cloud' ? cloudPath : wavePath} fill="currentColor"></path>
  </svg>
</div>
