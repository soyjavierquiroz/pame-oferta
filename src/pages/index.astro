---
import BonusSection from '../components/BonusSection.astro';
import FeaturesGrid from '../components/FeaturesGrid.astro';
import Faq from '../components/Faq.astro';
import FinalCTA from '../components/FinalCTA.astro';
import Hero from '../components/Hero.astro';
import SectionWave from '../components/SectionWave.astro';
import SocialProof from '../components/SocialProof.astro';
import TransformationShowcase from '../components/TransformationShowcase.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
  <main>
    <Hero />
    <SectionWave className="text-brand-canvas-50" />
    <TransformationShowcase />
    <SectionWave className="text-brand-canvas-50" />
    <FeaturesGrid />
    <SectionWave className="text-brand-mint-100" />
    <SocialProof />
    <SectionWave className="text-brand-lilac-50" />
    <BonusSection />
    <SectionWave className="text-brand-canvas-100" />
    <Faq />
    <SectionWave className="text-brand-plum-900" />
    <FinalCTA />
  </main>
</BaseLayout>
